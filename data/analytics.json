  "heatmap_captura": {
    "ativo": true,
    "frequencia_ms": 1200,
    "eventos": ["click", "mousemove", "scroll"],
    "anonimizacao": true
  },

  "alertas": [
    {
      "id": "erro_critico",
      "condicao": "erro_js >= 5 por minuto",
      "mensagem": "Muitos erros JS detectados",
      "acao": "notificar_admin"
    },
    {
      "id": "trafego_alto",
      "condicao": "page_view >= 5000 por hora",
      "mensagem": "Pico de tráfego detectado",
      "acao": "ativar_auto_scale"
    }
  ],

  "retencao_dias": 120
}