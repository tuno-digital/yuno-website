    },
    {
      "id": "click",
      "tipo": "interacao",
      "descricao": "Utilizador clicou num elemento"
    },
    {
      "id": "scroll",
      "tipo": "interacao",
      "descricao": "Utilizador fez scroll"
    },
    {
      "id": "form_submit",
      "tipo": "conversao",
      "descricao": "Formulário enviado"
    },
    {
      "id": "lead_capturado",
      "tipo": "conversao",
      "descricao": "Novo lead registado"
    },
    {
      "id": "erro_js",
      "tipo": "erro",
      "descricao": "Erro JavaScript capturado"
    }
  ],

  "funis": [
    {
      "id": "funnel_site",
      "nome": "Funil do Site",
      "etapas": [
        "Visitou Página Inicial",
        "Viu Serviços",
        "Abriu Contacto",
        "Enviou Mensagem"
      ]
    },
    {
      "id": "funnel_yuno_ia",
      "nome": "Funil Jarvis/Yuno IA",
