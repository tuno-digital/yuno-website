# ============================================================
# 🔐 KEYS DA YUNO (INTEGRAÇÕES OFICIAIS) — Versão 10.3
# ============================================================

# 🔊 HeyGen — Voz/Avatar
HEYGEN_API_KEY=

# 🎬 Pika Labs — Vídeo IA
PIKA_API_KEY=

# 🎥 RunwayML — Vídeo e Efeitos IA
RUNWAY_API_KEY=

# 🧠 OpenAI / OpenRouter / YUNO Engine
YUNO_AI_KEY=


# ============================================================
# ⚙️ CONFIGURAÇÃO DO SERVIDOR LOCAL (VIDEO ENGINE / BACKEND)
# ============================================================

# Porta interna do servidor de vídeo / backend principal
PORT=3001

# Ambiente atual
# Opções: development | production
NODE_ENV=development


# ============================================================
# 🌐 CONFIG PWA / SITE (IMPORTANTE!)
# ============================================================

# URL base do site
# Exemplo local: http://localhost:3000
# Exemplo produção: https://teusite.com
SITE_URL=

# Caminho do Service Worker
SERVICE_WORKER=/service-worker.js


# ============================================================
# 🧩 CONFIG YUNO 10.3 — SISTEMA INTERNO
# ============================================================

# Ativar logs detalhados e sistema de auto-programação
YUNO_DEBUG=true

# Versão ativa da Yuno
YUNO_VERSION=10.3

# Token interno (obrigatório para área secreta)
YUNO_INTERNAL_TOKEN=

# Token extra para sessões seguras
YUNO_SESSION_SECRET=


# ============================================================
# 📡 CONFIG AUTOMAÇÕES / API INTERNA
# ============================================================

# Endpoint da API interna (para yuno-client.js)
# Exemplo local: http://localhost:3001
YUNO_API_URL=

# Ativar/desativar automações avançadas
YUNO_AUTOMATIONS_ENABLED=true
