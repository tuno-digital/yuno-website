# ============================================================
# 🔐 KEYS DA YUNO — Integrações Oficiais (10.3)
# ============================================================

HEYGEN_API_KEY=
PIKA_API_KEY=
RUNWAY_API_KEY=
OPENAI_API_KEY=
YUNO_AI_KEY=

# Token interno da IA (utilizado para módulos secretos)
YUNO_INTERNAL_TOKEN=

# Token para sessões internas do Admin Panel
YUNO_SESSION_SECRET=


# ============================================================
# ⚙️ CONFIGURAÇÃO DO SERVIDOR BACKEND
# ============================================================

PORT=3001
NODE_ENV=development


# ============================================================
# 🌐 CONFIG PWA / SITE
# ============================================================

# URL base do teu website
SITE_URL=http://localhost:3000

# Caminho do teu service worker
SERVICE_WORKER=/service-worker.js


# ============================================================
# 🧠 CONFIG YUNO IA — SISTEMA INTERNO
# ============================================================

# Ativa logs detalhados + auto-programação
YUNO_DEBUG=false

# Versão interna da IA
YUNO_VERSION=10.3


# ============================================================
# 📡 CONFIG AUTOMAÇÕES / API INTERNA
# ============================================================

# URL da API local ou de produção da Yuno
YUNO_API_URL=http://localhost:3001

# Ativar/desativar automações internas
YUNO_AUTOMATIONS_ENABLED=true
