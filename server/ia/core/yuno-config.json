{
  "ai": {
    "model": "gpt-5.1",
    "temperature": 0.7,
    "maxTokens": 2048,
    "key": "USE_ENV",
    "endpoint": "https://api.openai.com/v1/chat/completions"
  },

  "personality": {
    "comportamento": "Confiante, inteligente, rápida, objetiva, com estilo futurista.",
    "objetivo": "Ajudar o utilizador e evoluir a plataforma com disciplina."
  },

  "memory": {
    "ativa": true,
    "maxLongTerm": 5000
  },

  "commands": {
    "ativados": true
  },

  "security": {
    "antiSpam": true,
    "rateLimit": true
  },

  "version": "10.3",
  "engine": "hybrid-neon"
}
