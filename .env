# ============================================================
# 🔐 KEYS DA YUNO (INTEGRAÇÕES OFICIAIS) — Versão 10.3
# ============================================================

# 🔊 HeyGen — Voz/Avatar
HEYGEN_API_KEY=COLOCA_AQUI_TUA_KEY

# 🎬 Pika Labs — Vídeo IA
PIKA_API_KEY=COLOCA_AQUI_TUA_KEY

# 🎥 RunwayML — Vídeo e Efeitos IA
RUNWAY_API_KEY=COLOCA_AQUI_TUA_KEY

# 🧠 OpenAI / OpenRouter / YUNO Engine (dependente do motor escolhido)
YUNO_AI_KEY=COLOCA_AQUI_TUA_KEY


# ============================================================
# ⚙️ CONFIGURAÇÃO DO SERVIDOR LOCAL (VIDEO ENGINE / BACKEND)
# ============================================================

# Porta interna do servidor de vídeo
PORT=3001

# Definição de ambiente
NODE_ENV=development
# Opções possíveis: development | production


# ============================================================
# 🌐 CONFIG PWA / SITE
# ============================================================

# URL base do projeto (IMPORTANTE para SW + Manifest)
SITE_URL=https://teusite.com

# Caminho do Service Worker
SERVICE_WORKER=/service-worker.js


# ============================================================
# 🧩 CONFIG YUNO 10.3 — SISTEMA INTERNO
# ============================================================

# Activar modo debug da Yuno (logs detalhados)
YUNO_DEBUG=true

# Versão atual da Yuno (usada pelo painel, SW e logs)
YUNO_VERSION=10.3

# Chave interna para módulos avançados (não obrigatória)
YUNO_INTERNAL_TOKEN=CHAVE_INTERNA_OPCIONAL


# ============================================================
# 📡 CONFIG AUTOMAÇÕES / API INTERNA
# ============================================================

# Endpoint da API interna (usado por yuno-client.js)
YUNO_API_URL=http://localhost:3001

# Ativar/desativar automações
YUNO_AUTOMATIONS_ENABLED=true
